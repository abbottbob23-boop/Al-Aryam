<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Al Aryam Tailoring — Bespoke Suits, Al Bada', Dubai</title>
<meta name="description" content="Bespoke suits and shirts, fitted right the first time. Al Aryam Tailoring, Sheikh Mouza Dalmook Building, Al Bada', Dubai.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --navy: #1B2430;
    --navy-deep: #121821;
    --cream: #F0ECE3;
    --brass: #B08D57;
    --burgundy: #6E2A32;
    --line: rgba(27,36,48,0.14);
    --radius: 3px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{background:var(--cream); color:var(--navy); font-family:'Work Sans', sans-serif;}
  h1,h2,h3,.display{font-family:'Cormorant Garamond', serif;}
  .mono{font-family:'IBM Plex Mono', monospace; letter-spacing:0.04em;}
  a{color:inherit; text-decoration:none;}
  .wrap{max-width:1100px; margin:0 auto; padding:0 28px;}

  /* ===== NAV ===== */
  nav{position:sticky; top:0; z-index:50; background:rgba(240,236,227,0.92); backdrop-filter:blur(6px); border-bottom:1px solid var(--line);}
  nav .wrap{display:flex; align-items:center; justify-content:space-between; height:78px;}
  .logo{font-family:'Cormorant Garamond',serif; font-weight:700; font-size:1.5rem; letter-spacing:0.01em;}
  .logo small{display:block; font-family:'IBM Plex Mono',monospace; font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--brass); margin-top:1px;}
  .navlinks{display:flex; gap:30px; font-size:0.88rem; font-weight:500;}
  .navlinks a{opacity:0.72; border-bottom:1px solid transparent; padding-bottom:3px; transition:.2s;}
  .navlinks a:hover{opacity:1; border-color:var(--brass);}
  .nav-cta{background:var(--navy); color:var(--cream); padding:10px 20px; font-size:0.82rem; font-weight:600; border-radius:var(--radius);}
  @media (max-width:760px){ .navlinks{display:none;} }

  /* ===== HERO — measuring tape signature ===== */
  .hero{position:relative; padding:90px 0 40px; overflow:hidden; border-bottom:1px solid var(--line);}
  .hero .wrap{position:relative; z-index:2;}
  .eyebrow{display:inline-flex; align-items:center; gap:10px; font-family:'IBM Plex Mono',monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.16em; color:var(--brass); margin-bottom:20px;}
  .hero h1{font-size:clamp(2.5rem,5.5vw,4rem); line-height:1.08; font-weight:600; max-width:16ch; margin-bottom:22px;}
  .hero h1 em{font-style:italic; color:var(--burgundy);}
  .hero p.lede{font-size:1.08rem; line-height:1.75; opacity:0.8; max-width:50ch; margin-bottom:34px;}
  .hero-actions{display:flex; gap:14px; flex-wrap:wrap; margin-bottom:56px;}
  .btn{display:inline-flex; align-items:center; gap:8px; padding:14px 26px; font-size:0.88rem; font-weight:600; border-radius:var(--radius); transition:.2s;}
  .btn-primary{background:var(--navy); color:var(--cream);}
  .btn-primary:hover{background:var(--burgundy);}
  .btn-ghost{border:1.5px solid var(--navy);}
  .btn-ghost:hover{background:var(--navy); color:var(--cream);}

  /* measuring tape strip */
  .tape{width:100%; height:64px; position:relative;}
  .tape svg{width:100%; height:100%; display:block;}
  .tape-line{stroke:var(--navy); stroke-width:2; opacity:0.35;}
  .tape-tick-major{stroke:var(--navy); stroke-width:2;}
  .tape-tick-minor{stroke:var(--navy); stroke-width:1; opacity:0.4;}
  .tape-thread{
    stroke:var(--burgundy); stroke-width:2; fill:none; stroke-linecap:round;
    stroke-dasharray:1400; stroke-dashoffset:1400;
    animation:stitch 3.5s ease-out forwards;
  }
  @keyframes stitch{ to{ stroke-dashoffset:0; } }
  @media (prefers-reduced-motion: reduce){ .tape-thread{animation:none; stroke-dashoffset:0;} }
  .tape-label{font-family:'IBM Plex Mono',monospace; font-size:9px; fill:var(--navy); opacity:0.55;}

  /* ===== SECTIONS ===== */
  section{padding:80px 0;}
  .kicker{font-family:'IBM Plex Mono',monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.14em; color:var(--brass); margin-bottom:14px;}
  .section-head{max-width:56ch; margin-bottom:44px;}
  .section-head h2{font-size:clamp(1.8rem,3vw,2.4rem); font-weight:600;}
  .rule{height:1px; background:var(--line);}

  /* ===== ABOUT ===== */
  .about-grid{display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center;}
  .about-grid p{line-height:1.85; opacity:0.85; margin-bottom:16px; font-size:1.02rem;}
  .about-photo{
    aspect-ratio:4/5; border:1px solid var(--line); border-radius:var(--radius);
    background:
      linear-gradient(160deg, rgba(27,36,48,0.9), rgba(110,42,50,0.75));
    display:flex; align-items:center; justify-content:center; text-align:center; padding:24px;
    font-family:'IBM Plex Mono',monospace; font-size:0.78rem; color:var(--cream); opacity:0.85; text-transform:uppercase; letter-spacing:0.06em;
  }
  @media (max-width:820px){ .about-grid{grid-template-columns:1fr;} }

  /* ===== SPEC SHEET / MEASUREMENTS AS MENU ===== */
  .spec-sheet{border:1px solid var(--navy); border-radius:var(--radius); overflow:hidden;}
  .spec-row{
    display:grid; grid-template-columns:1fr auto auto; gap:20px; align-items:baseline;
    padding:18px 26px; border-bottom:1px solid var(--line);
  }
  .spec-row:last-child{border-bottom:none;}
  .spec-row.head{background:var(--navy); color:var(--cream); font-family:'IBM Plex Mono',monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em;}
  .spec-row .name{font-family:'Cormorant Garamond',serif; font-size:1.2rem; font-weight:600;}
  .spec-row .desc{font-size:0.85rem; opacity:0.65; display:block; margin-top:2px; font-family:'Work Sans',sans-serif;}
  .spec-row .fittings{font-family:'IBM Plex Mono',monospace; font-size:0.78rem; opacity:0.6; white-space:nowrap;}
  .spec-row .price{font-family:'IBM Plex Mono',monospace; font-weight:600; color:var(--burgundy); white-space:nowrap;}

  /* ===== FIND US ===== */
  .find-wrap{display:grid; grid-template-columns:1fr 1fr; gap:0; border:1px solid var(--navy); border-radius:var(--radius); overflow:hidden;}
  .find-panel{padding:44px;}
  .find-panel.dark{background:var(--navy); color:var(--cream);}
  .find-panel h3{font-size:1.3rem; margin-bottom:20px; font-weight:600;}
  .hours-row{display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--line); font-family:'IBM Plex Mono',monospace; font-size:0.9rem;}
  .find-panel.dark .hours-row{border-bottom:1px solid rgba(240,236,227,0.16);}
  .hours-row.short span:last-child{color:var(--brass);}
  .contact-line{display:flex; gap:14px; margin-bottom:16px; font-size:0.94rem;}
  .contact-line .k{font-family:'IBM Plex Mono',monospace; font-size:0.7rem; text-transform:uppercase; opacity:0.6; min-width:64px; padding-top:2px;}
  @media (max-width:820px){ .find-wrap{grid-template-columns:1fr;} }

  footer{padding:44px 0; border-top:1px solid var(--line);}
  footer .wrap{display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;}
  footer .fine{font-family:'IBM Plex Mono',monospace; font-size:0.75rem; opacity:0.55;}
</style>
</head>
<body>

<nav>
  <div class="wrap">
    <div class="logo">Al Aryam<small>Tailoring</small></div>
    <div class="navlinks">
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#find">Visit</a>
    </div>
    <a class="nav-cta" href="https://www.google.com/maps/dir/?api=1&destination=25.230945,55.2754461" target="_blank" rel="noopener">Directions</a>
  </div>
</nav>

<section class="hero">
  <div class="wrap">
    <div class="eyebrow">Sheikh Mouza Dalmook Building · Al Bada', Dubai</div>
    <h1>Fitted right the <em>first</em> time.</h1>
    <p class="lede">Suits and shirts, made to measure by hand. No second fitting because you needed one — because we got it right. Ishwar and the team have been Al Bada's tailor of choice for years, one careful measurement at a time.</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="tel:+971508453884">Call: 050 845 3884</a>
      <a class="btn btn-ghost" href="#services">See services</a>
    </div>
  </div>
  <div class="tape">
    <svg viewBox="0 0 1100 64" preserveAspectRatio="none">
      <line class="tape-line" x1="0" y1="32" x2="1100" y2="32"/>
      <g class="mono">
        <!-- tick marks every 20px, major every 100 -->
        <g id="ticks"></g>
      </g>
      <path class="tape-thread" d="M0 46 Q 40 18, 80 46 T 160 46 T 240 46 T 320 46 T 400 46 T 480 46 T 560 46 T 640 46 T 720 46 T 800 46 T 880 46 T 960 46 T 1040 46 T 1100 46"/>
    </svg>
  </div>
</section>

<section id="about">
  <div class="wrap">
    <div class="kicker">The Shop</div>
    <div class="about-grid">
      <div>
        <h2 style="margin-bottom:22px; font-weight:600; font-size:1.9rem;">A small shop, a sharp needle</h2>
        <p>Al Aryam is a one-room tailoring shop in Al Bada' — no chain, no franchise, just a team that's built its name on suits and shirts that fit correctly the first time you try them on.</p>
        <p>Regulars come back for the same reason every time: honest advice on fit and fabric, fair prices, and a team that treats every order — from a single shirt to a full suit — with the same attention to detail.</p>
      </div>
      <div class="about-photo">Photo — fitting room<br>and fabric selection</div>
    </div>
  </div>
</section>

<div class="wrap"><div class="rule"></div></div>

<section id="services">
  <div class="wrap">
    <div class="section-head">
      <div class="kicker">Services</div>
      <h2>Made to your measurements</h2>
    </div>
    <div class="spec-sheet">
      <div class="spec-row head"><span>Item</span><span>Fittings</span><span>From</span></div>
      <div class="spec-row"><span class="name">Bespoke Suit<span class="desc">Full two-piece, your choice of fabric</span></span><span class="fittings">2–3 fittings</span><span class="price">AED 750</span></div>
      <div class="spec-row"><span class="name">Tailored Shirt<span class="desc">Cotton or linen, made to measure</span></span><span class="fittings">1–2 fittings</span><span class="price">AED 150</span></div>
      <div class="spec-row"><span class="name">Trousers<span class="desc">Matched or standalone</span></span><span class="fittings">1–2 fittings</span><span class="price">AED 200</span></div>
      <div class="spec-row"><span class="name">Alterations<span class="desc">Hemming, resizing, repairs</span></span><span class="fittings">Same day, often</span><span class="price">AED 40</span></div>
    </div>
  </div>
</section>

<div class="wrap"><div class="rule"></div></div>

<section id="find">
  <div class="wrap">
    <div class="section-head">
      <div class="kicker">Visit</div>
      <h2>Hours &amp; how to reach us</h2>
    </div>
    <div class="find-wrap">
      <div class="find-panel">
        <h3>Opening Hours</h3>
        <div class="hours-row"><span>Mon – Thu</span><span>9:00–13:00, 16:00–22:00</span></div>
        <div class="hours-row short"><span>Fri</span><span>9:00–12:00, 16:00–18:00</span></div>
        <div class="hours-row"><span>Sat – Sun</span><span>9:00–13:00, 16:00–22:00</span></div>
      </div>
      <div class="find-panel dark">
        <h3>Get in Touch</h3>
        <div class="contact-line"><span class="k">Address</span><span>Shop #6, Sheikh Mouza Dalmook Building, 17B St, Al Bada', Dubai</span></div>
        <div class="contact-line"><span class="k">Phone</span><span><a href="tel:+971508453884">050 845 3884</a></span></div>
        <a class="btn btn-primary" style="margin-top:8px; background:var(--brass); color:var(--navy-deep);" href="https://www.google.com/maps/dir/?api=1&destination=25.230945,55.2754461" target="_blank" rel="noopener">Open in Google Maps</a>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="wrap">
    <div class="logo" style="font-size:1.05rem;">Al Aryam Tailoring</div>
    <div class="fine">© 2026 Al Aryam Tailoring, Al Bada', Dubai</div>
  </div>
</footer>

<script>
  // generate tick marks along the measuring tape
  const ticksGroup = document.getElementById('ticks');
  let svgTicks = '';
  for (let x = 0; x <= 1100; x += 20) {
    const isMajor = (x % 100 === 0);
    svgTicks += `<line class="${isMajor ? 'tape-tick-major' : 'tape-tick-minor'}" x1="${x}" y1="24" x2="${x}" y2="${isMajor ? 40 : 32}"/>`;
    if (isMajor) {
      svgTicks += `<text class="tape-label" x="${x + 4}" y="20">${x/20}</text>`;
    }
  }
  ticksGroup.innerHTML = svgTicks;
</script>

</body>
</html>
